# Preseed values for run_rhis_install_sequence.sh
# Shell-compatible syntax only. Quote values that contain spaces.
# This file is loaded automatically at startup from the same directory as the script.
#
# CLI usage examples:
#   ./run_rhis_install_sequence.sh                              (interactive menu)
#   ./run_rhis_install_sequence.sh --DEMO                       (DEMO mode, interactive menu)
#   ./run_rhis_install_sequence.sh --DEMO --menu-choice 3       (DEMO mode, option 3)
#   ./run_rhis_install_sequence.sh --non-interactive --menu-choice 3  (fully unattended)
#   ./run_rhis_install_sequence.sh --env-file /path/to/other.env

# ---------------------------------------------------------------------------
# CONTROL
# ---------------------------------------------------------------------------

# Disable interactive prompts when set to 1. All required variables must be
# filled in below. Leave as 0 for an interactive run.
NONINTERACTIVE=0

# DEMO mode: use minimal PoC/learning VM sizes and kickstarts instead of
# production best-practice specs. Equivalent to passing --DEMO on the CLI.
#
#   DEMO resource requirements:
#     Satellite : 8 vCPU  24 GB RAM  100 GB disk  (/boot 2G + swap 18G + / rest)
#     AAP       : 4 vCPU   8 GB RAM   50 GB disk  (/boot 2G + swap 10G + / rest)
#     IdM       : 2 vCPU   4 GB RAM   30 GB disk  (/boot 2G + swap  4G + / rest)
#
#   Standard (production) requirements:
#     Satellite : 8 vCPU  32 GB RAM   75 GB disk  (LVM: /boot+swap+/+/var grow)
#     AAP       : 8 vCPU  16 GB RAM   50 GB disk  (LVM: /boot+swap+/+/var grow)
#     IdM       : 4 vCPU  16 GB RAM   60 GB disk  (LVM: /boot+swap+/+/var grow)
DEMO_MODE=1

# Preseed the main menu choice (comment out to get the interactive menu).
#   1 = Local Installation (npm)
#   2 = Container Deployment (Podman)
#   3 = Setup Virt-Manager + create all VMs  <-- recommended for full DEMO setup
#   4 = Full Setup (Local + Virt-Manager)
#   5 = Full Setup (Container + Virt-Manager)
#   6 = Generate Satellite OEMDRV ISO only
#   7 = Exit
MENU_CHOICE=3

# Override the preseed file path (optional — CLI --env-file takes precedence).
# PRESEED_ENV_FILE=/path/to/custom.env

# ---------------------------------------------------------------------------
# RHEL ISO AUTHENTICATION
# ---------------------------------------------------------------------------
# 1 = manual portal login + paste URL
# 2 = Red Hat offline token (recommended for automation)
RH_AUTH_CHOICE=2
RH_ISO_URL=""
RH_OFFLINE_TOKEN=""
RH_ACCESS_TOKEN=""

# ---------------------------------------------------------------------------
# SHARED RED HAT CDN CREDENTIALS
# Used by Satellite, AAP, and IdM post-install registration.
# ---------------------------------------------------------------------------
RH_USER=""
RH_PASS=""

# ---------------------------------------------------------------------------
# SATELLITE 6.18
# eth0 = external (DHCP)
# eth1 = internal (static — Satellite IS the DHCP server for this network)
# ---------------------------------------------------------------------------
SAT_IP="192.168.122.50"
SAT_NETMASK="255.255.255.0"
SAT_GW="192.168.122.1"
SAT_HOSTNAME="satellite-618.example.com"
SAT_DOMAIN="example.com"
SAT_ORG="ExampleOrg"
SAT_LOC="ExampleLab"

# ---------------------------------------------------------------------------
# AAP 2.6
# eth0 = external (DHCP)
# eth1 = internal (DHCP from Satellite in both DEMO and standard mode)
# RH_USER / RH_PASS reuse the shared credentials above.
# ---------------------------------------------------------------------------
AAP_HOSTNAME="aap-26.example.com"
AAP_DOMAIN="example.com"

# ---------------------------------------------------------------------------
# IdM (Red Hat Identity Management)
# eth0 = external (DHCP)
# eth1 = internal:
#   DEMO mode    — DHCP from Satellite (no static IP needed)
#   Standard mode — static IP (uncomment IDM_IP / IDM_NETMASK / IDM_GW below)
# RH_USER / RH_PASS reuse the shared credentials above.
# ---------------------------------------------------------------------------
IDM_HOSTNAME="idm.example.com"
IDM_DOMAIN="example.com"
IDM_REALM="EXAMPLE.COM"
IDM_ADMIN_PASS=""
IDM_DS_PASS=""
# Standard-mode eth1 static address (not used in DEMO mode):
# IDM_IP="10.168.0.11"
# IDM_NETMASK="255.255.0.0"
# IDM_GW="10.168.0.1"

# ---------------------------------------------------------------------------
# OPTIONAL PATH OVERRIDES (defaults shown)
# --------------------------------------------------------------------------- + Virt-Manager)
#   5 = Full Setup (Container + Virt-Manager)
#   6 = Generate Satellite OEMDRV ISO only
#   7 = Exit
MENU_CHOICE=3

# Override the preseed file path (optional — CLI --env-file takes precedence).
# PRESEED_ENV_FILE=/path/to/custom.env

# ---------------------------------------------------------------------------
# RHEL ISO AUTHENTICATION
# ---------------------------------------------------------------------------
# 1 = manual portal login + paste URL
# 2 = Red Hat offline token (recommended for automation)
RH_AUTH_CHOICE=2
RH_ISO_URL=""
RH_OFFLINE_TOKEN=""
RH_ACCESS_TOKEN=""

# ---------------------------------------------------------------------------
# SHARED RED HAT CDN CREDENTIALS
# Used by Satellite, AAP, and IdM post-install registration.
# ---------------------------------------------------------------------------
RH_USER=""
RH_PASS=""

# ---------------------------------------------------------------------------
# SATELLITE 6.18
# eth0 = external (DHCP)
# eth1 = internal (static — Satellite IS the DHCP server for this network)
# ---------------------------------------------------------------------------
SAT_IP="192.168.122.50"
SAT_NETMASK="255.255.255.0"
SAT_GW="192.168.122.1"
SAT_HOSTNAME="satellite-618.example.com"
SAT_DOMAIN="example.com"
SAT_ORG="ExampleOrg"
SAT_LOC="ExampleLab"

# ---------------------------------------------------------------------------
# AAP 2.6
# eth0 = external (DHCP)
# eth1 = internal (DHCP from Satellite in both DEMO and standard mode)
# RH_USER / RH_PASS reuse the shared credentials above.
# ---------------------------------------------------------------------------
AAP_HOSTNAME="aap-26.example.com"
AAP_DOMAIN="example.com"

# ---------------------------------------------------------------------------
# IdM (Red Hat Identity Management)
# eth0 = external (DHCP)
# eth1 = internal:
#   DEMO mode    — DHCP from Satellite (no static IP needed)
#   Standard mode — static IP (uncomment IDM_IP / IDM_NETMASK / IDM_GW below)
# RH_USER / RH_PASS reuse the shared credentials above.
# ---------------------------------------------------------------------------
IDM_HOSTNAME="idm.example.com"
IDM_DOMAIN="example.com"
IDM_REALM="EXAMPLE.COM"
IDM_ADMIN_PASS=""
IDM_DS_PASS=""
# Standard-mode eth1 static address (not used in DEMO mode):
# IDM_IP="10.168.0.11"
# IDM_NETMASK="255.255.0.0"
# IDM_GW="10.168.0.1"

# ---------------------------------------------------------------------------
# OPTIONAL PATH OVERRIDES (defaults shown)
# ---------------------------------------------------------------------------
# ISO_DIR=/var/lib/libvirt/images
# ISO_NAME=rhel-10-everything-x86_64-dvd.iso
# ISO_PATH=/var/lib/libvirt/images/rhel-10-everything-x86_64-dvd.iso
# VM_DIR=/var/lib/libvirt/images
# KS_DIR=/var/lib/libvirt/images/kickstarts
# OEMDRV_ISO=/var/lib/libvirt/images/OEMDRV.iso
